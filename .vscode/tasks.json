{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar ERP 2.0",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$files = Get-ChildItem 'src','UTIL' -Recurse -Filter *.java | ForEach-Object FullName; & javac --module-path 'C:/javafx-sdk-24.0.1/lib' --add-modules javafx.controls,javafx.fxml -cp 'lib/mysql-connector-java-9.3.0.jar' -d 'bin' $files"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
