<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="vendaFormRoot"
      maxWidth="1200.0"
      spacing="18.0"
      styleClass="page"
      xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="erp.controller.TelaVendasController">

   <padding>
      <Insets top="22.0" right="22.0" bottom="22.0" left="22.0" />
   </padding>

   <children>

      <VBox spacing="6.0">
         <children>
            <Label text="Nova Venda" styleClass="page-title" />
            <Label text="Monte a venda, adicione os itens e finalize o pagamento"
                   styleClass="page-subtitle" />
         </children>
      </VBox>

      <HBox spacing="18.0">
         <children>

            <VBox spacing="14.0" HBox.hgrow="ALWAYS">
               <children>
                  <VBox spacing="14.0" styleClass="card">
                     <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                     </padding>

                     <children>
                        <Label text="Item da venda" styleClass="section-title" />

                        <GridPane hgap="12.0" vgap="12.0">
                           <columnConstraints>
                              <ColumnConstraints halignment="LEFT" hgrow="NEVER" minWidth="10.0" prefWidth="120.0" />
                              <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="250.0" />
                              <ColumnConstraints halignment="LEFT" hgrow="NEVER" minWidth="10.0" prefWidth="140.0" />
                              <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="230.0" />
                           </columnConstraints>

                           <rowConstraints>
                              <RowConstraints minHeight="10.0" prefHeight="30.0" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" />
                           </rowConstraints>

                           <children>
                              <Label text="Produto" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                              <ComboBox fx:id="cbProduto" prefWidth="Infinity"
                                        GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="0" />

                              <Label text="Tipo" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                              <ComboBox fx:id="cbTipo" prefWidth="Infinity"
                                        GridPane.columnIndex="1" GridPane.rowIndex="1" />

                              <Label text="Tamanhos" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                              <FlowPane fx:id="fpTamanhosDisponiveis"
                                        hgap="10.0" vgap="10.0"
                                        prefWidth="Infinity"
                                        GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="2">
                                 <padding>
                                    <Insets top="4.0" bottom="4.0" />
                                 </padding>
                              </FlowPane>

                              <Label text="Quantidade" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                              <TextField fx:id="txtQuantidadeVendida"
                                         GridPane.columnIndex="1" GridPane.rowIndex="3" />

                              <Label text="Preço unitário (R$)" styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                              <TextField fx:id="txtValorVenda"
                                         GridPane.columnIndex="3" GridPane.rowIndex="3" />
                           </children>
                        </GridPane>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Button fx:id="btnAdicionarItem"
                                      mnemonicParsing="false"
                                      prefWidth="150.0"
                                      text="Adicionar item"
                                      styleClass="btn-primary" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <VBox spacing="14.0" styleClass="card">
                     <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                     </padding>

                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label text="Itens adicionados" styleClass="section-title" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Button fx:id="btnRemoverItem"
                                      disable="true"
                                      mnemonicParsing="false"
                                      text="Remover item"
                                      styleClass="btn-secondary" />
                           </children>
                        </HBox>

                        <TableView fx:id="tblItensVenda" prefHeight="230.0">
                           <columns>
                              <TableColumn fx:id="colItemProduto" prefWidth="230.0" text="Produto" />
                              <TableColumn fx:id="colItemTipo" prefWidth="100.0" text="Tipo" />
                              <TableColumn fx:id="colItemTamanho" prefWidth="80.0" text="Tam." />
                              <TableColumn fx:id="colItemQuantidade" prefWidth="80.0" text="Qtd." />
                              <TableColumn fx:id="colItemPrecoUnitario" prefWidth="120.0" text="Preço unit." />
                              <TableColumn fx:id="colItemTotal" prefWidth="120.0" text="Total" />
                           </columns>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </VBox>

            <VBox spacing="14.0" prefWidth="360.0">
               <children>
                  <VBox spacing="14.0" styleClass="card">
                     <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                     </padding>

                     <children>
                        <Label text="Dados da venda" styleClass="section-title" />

                        <GridPane hgap="10.0" vgap="10.0">
                           <columnConstraints>
                              <ColumnConstraints halignment="LEFT" hgrow="NEVER" prefWidth="120.0" />
                              <ColumnConstraints hgrow="ALWAYS" prefWidth="190.0" />
                           </columnConstraints>

                           <children>
                              <Label text="Cliente" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                              <TextField fx:id="txtNomeCliente" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                              <Label text="Data" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                              <DatePicker fx:id="dpDataVenda" prefWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                              <Label text="Desconto (R$)" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                              <TextField fx:id="txtDesconto" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                              <Label text="Pago" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                              <CheckBox fx:id="chkPago" mnemonicParsing="false" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                              <Label text="Data prometida" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                              <DatePicker fx:id="dpDataPrometida" prefWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                              <Label text="Pagamento" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                              <ComboBox fx:id="cbMetodoPagamento" prefWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                           </children>
                        </GridPane>
                     </children>
                  </VBox>

                  <VBox spacing="12.0" styleClass="card">
                     <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                     </padding>

                     <children>
                        <Label text="Resumo" styleClass="section-title" />

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label text="Subtotal" styleClass="kpi-title" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="lblSubtotalCalculado" text="R$ 0,00" />
                           </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label text="Desconto aplicado" styleClass="kpi-title" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="lblDescontoAplicado" text="R$ 0,00" />
                           </children>
                        </HBox>

                        <Separator />

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label text="Total a pagar" styleClass="kpi-title" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="lblTotalAPagar" text="R$ 0,00" styleClass="kpi-value-success" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <VBox fx:id="infoGlobalVendasBox" spacing="8.0" styleClass="card">
                     <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                     </padding>

                     <children>
                        <Label text="Indicadores do mês" styleClass="section-title" />
                        <Label fx:id="lblFaturamento"
                               styleClass="muted-label"
                               text="Faturamento do Mês (Pago): R$ 0,00" />
                        <Label fx:id="lblQuantidadeVendas"
                               styleClass="muted-label"
                               text="Vendas no Mês: 0" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </HBox>

      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="btnLimparCampos"
                    mnemonicParsing="false"
                    onAction="#limparFormularioVenda"
                    prefWidth="150.0"
                    text="Limpar Venda"
                    styleClass="btn-secondary" />

            <Button fx:id="btnSalvarVenda"
                    mnemonicParsing="false"
                    prefWidth="150.0"
                    text="Finalizar Venda"
                    styleClass="btn-primary" />
         </children>
      </HBox>

   </children>
</VBox>
