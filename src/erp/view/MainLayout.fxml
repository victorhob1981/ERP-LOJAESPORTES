<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane fx:id="mainBorderPane"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="app-root"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="erp.controller.MainLayoutController">

   <!-- CSS global do layout (somente visual) -->
   <stylesheets>
      <URL value="@erp-modern.css" />
   </stylesheets>

   <!--
        A UI do print não usa MenuBar, mas manter aqui (oculta) preserva os atalhos/ações
        sem mexer na lógica do controller.
   -->
   <top>
      <MenuBar fx:id="mainMenuBar" managed="false" visible="false" BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="Arquivo">
            <items>
              <MenuItem onAction="#acaoSair" text="Sair" />
            </items>
          </Menu>
           <Menu mnemonicParsing="false" text="Navegar">
            <items>
              <MenuItem onAction="#irParaDashboard" text="Painel Principal" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Relatórios">
            <items>
                <MenuItem onAction="#irParaHistoricoVendas" text="Histórico de Vendas" />
                <MenuItem onAction="#irParaFinanceiro" text="Resumo Financeiro" />
                <MenuItem fx:id="menuRelatorioProdutos" onAction="#irParaRelatorioProdutos" text="Relatório de Produtos" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Ajuda">
            <items>
              <MenuItem onAction="#mostrarSobre" text="Sobre" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>

   <left>
      <VBox fx:id="sidebar" prefWidth="240.0" spacing="10.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <padding>
            <Insets top="18.0" right="14.0" bottom="18.0" left="14.0" />
         </padding>

         <children>
            <Label text="ERP 2.0" styleClass="brand" />

            <Label text="NAVEGAÇÃO" styleClass="sidebar-section-title" />
            <Button fx:id="btnNavDashboard" onAction="#irParaDashboard" text="Painel Principal" styleClass="sidebar-button">
               <graphic>
                  <!-- layout-dashboard (simplificado) -->
                  <SVGPath styleClass="icon" content="M3 3h7v9H3z M14 3h7v5h-7z M14 12h7v9h-7z M3 16h7v5H3z" />
               </graphic>
            </Button>

            <Label text="VENDAS" styleClass="sidebar-section-title" />
            <Button fx:id="btnNavRegistrarVenda" onAction="#irParaRegistrarVenda" text="Nova Venda" styleClass="sidebar-button">
               <graphic>
                  <!-- shopping-cart (lucide) -->
                  <Group>
                     <SVGPath styleClass="icon" content="M1 1H5L7.68 14.39A2 2 0 0 0 9.68 16H19.4A2 2 0 0 0 21.4 14.39L23 6H6" />
                     <Circle styleClass="icon" centerX="9" centerY="21" radius="1" />
                     <Circle styleClass="icon" centerX="20" centerY="21" radius="1" />
                  </Group>
               </graphic>
            </Button>

            <Button fx:id="btnNavHistoricoVendas" onAction="#irParaHistoricoVendas" text="Histórico de Vendas" styleClass="sidebar-button">
               <graphic>
                  <!-- list (lucide) -->
                  <SVGPath styleClass="icon" content="M8 6H21 M8 12H21 M8 18H21 M3 6H3.01 M3 12H3.01 M3 18H3.01" />
               </graphic>
            </Button>

            <Button fx:id="btnNavGerenciarEstoque" onAction="#irParaGerenciarEstoque" text="Visualizar Estoque" styleClass="sidebar-button">
               <graphic>
                  <!-- box (lucide) -->
                  <Group>
                     <SVGPath styleClass="icon" content="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                     <SVGPath styleClass="icon" content="M3.27 6.96L12 12.01L20.73 6.96" />
                     <SVGPath styleClass="icon" content="M12 22.08V12" />
                  </Group>
               </graphic>
            </Button>

            <Button fx:id="btnNavCatalogo" onAction="#irParaCatalogo" text="Catálogo" styleClass="sidebar-button">
               <graphic>
                  <!-- image (lucide simplified) -->
                  <Group>
                     <SVGPath styleClass="icon" content="M3 5A2 2 0 0 1 5 3H19A2 2 0 0 1 21 5V19A2 2 0 0 1 19 21H5A2 2 0 0 1 3 19V5z" />
                     <Circle styleClass="icon" centerX="8.5" centerY="8.5" radius="1.5" />
                     <SVGPath styleClass="icon" content="M21 15L16 10L5 21" />
                  </Group>
               </graphic>
            </Button>

            <Label text="PEDIDOS" styleClass="sidebar-section-title" />
            <Button fx:id="btnNavRegistrarPedido" onAction="#irParaRegistrarPedido" text="Novo Pedido" styleClass="sidebar-button">
               <graphic>
                  <!-- box (reuse) -->
                  <SVGPath styleClass="icon" content="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
               </graphic>
            </Button>

            <Button fx:id="btnNavEncomendas" onAction="#irParaEncomendas" text="Encomendas" styleClass="sidebar-button">
               <graphic>
                  <!-- list (reuse) -->
                  <SVGPath styleClass="icon" content="M8 6H21 M8 12H21 M8 18H21 M3 6H3.01 M3 12H3.01 M3 18H3.01" />
               </graphic>
            </Button>

            <Button fx:id="btnNavAcompanhamento" onAction="#irParaAcompanhamento" text="Acompanhar Pedidos" styleClass="sidebar-button">
               <graphic>
                  <!-- code (lucide) -->
                  <SVGPath styleClass="icon" content="M16 18L22 12L16 6 M8 6L2 12L8 18" />
               </graphic>
            </Button>

            <Label text="RELATÓRIOS" styleClass="sidebar-section-title" />
            <Button fx:id="btnNavFinanceiro" onAction="#irParaFinanceiro" text="Resumo Financeiro" styleClass="sidebar-button">
               <graphic>
                  <!-- book (lucide) -->
                  <SVGPath styleClass="icon" content="M4 19.5A2.5 2.5 0 0 1 6.5 17H20 M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
               </graphic>
            </Button>

            <Button fx:id="btnNavRelatorioProdutos" mnemonicParsing="false" onAction="#irParaRelatorioProdutos" text="Relatório de Produtos" styleClass="sidebar-button">
               <graphic>
                  <SVGPath styleClass="icon" content="M8 6H21 M8 12H21 M8 18H21 M3 6H3.01 M3 12H3.01 M3 18H3.01" />
               </graphic>
            </Button>

            <Button fx:id="btnConfigBanco" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" onAction="#abrirConfiguracaoBanco">
               <styleClass>
                  <String fx:value="sidebar-button" />
                  <String fx:value="sidebar-icon-button" />
               </styleClass>
               <tooltip>
                  <Tooltip text="Configurar banco de dados" />
               </tooltip>
               <graphic>
                  <Group>
                     <SVGPath styleClass="icon" content="M12 15.5A3.5 3.5 0 1 0 12 8.5A3.5 3.5 0 0 0 12 15.5z" />
                     <SVGPath styleClass="icon" content="M19.4 15A1.65 1.65 0 0 0 19.73 16.82L19.79 16.88A2 2 0 1 1 16.96 19.71L16.9 19.65A1.65 1.65 0 0 0 15.08 19.32A1.65 1.65 0 0 0 14.08 20.83V21A2 2 0 1 1 10.08 21V20.91A1.65 1.65 0 0 0 9 19.4A1.65 1.65 0 0 0 7.18 19.73L7.12 19.79A2 2 0 1 1 4.29 16.96L4.35 16.9A1.65 1.65 0 0 0 4.68 15.08A1.65 1.65 0 0 0 3.17 14.08H3A2 2 0 1 1 3 10.08H3.09A1.65 1.65 0 0 0 4.6 9A1.65 1.65 0 0 0 4.27 7.18L4.21 7.12A2 2 0 1 1 7.04 4.29L7.1 4.35A1.65 1.65 0 0 0 8.92 4.68H9A1.65 1.65 0 0 0 10 3.17V3A2 2 0 1 1 14 3V3.09A1.65 1.65 0 0 0 15 4.6A1.65 1.65 0 0 0 16.82 4.27L16.88 4.21A2 2 0 1 1 19.71 7.04L19.65 7.1A1.65 1.65 0 0 0 19.32 8.92V9A1.65 1.65 0 0 0 20.83 10H21A2 2 0 1 1 21 14H20.91A1.65 1.65 0 0 0 19.4 15z" />
                  </Group>
               </graphic>
            </Button>
         </children>
      </VBox>
   </left>

   <center>
      <BorderPane fx:id="contentArea" styleClass="content-area" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
